<?xml version="1.0" encoding="utf-8"?>
<!-- FONDASI UTAMA: Menggunakan ConstraintLayout Murni Dengan Izin Resmi -->
<androidx.constraintlayout.widget.ConstraintLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://android.com"
    xmlns:app2="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://android.com"
    xmlns:tools2="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="#FFFFFF"
    tools:context=".BinaDesa.Profile.ProfileFragment">

    <!-- 1. BACKGROUND HEADER GRADASI UNGU (Dibuat Tipis Gaya Instagram) -->

    <!-- 2. BINGKAI FOTO PROFIL BULAT (Diposisikan di Kiri Atas Halaman) -->

    <View
        android:id="@+id/headerBackground"
        android:layout_width="413dp"
        android:layout_height="109dp"
        android:background="@drawable/gradient_profile_header"
        app2:layout_constraintEnd_toEndOf="parent"
        app2:layout_constraintHorizontal_bias="0.0"
        app2:layout_constraintStart_toStartOf="parent"
        app2:layout_constraintTop_toTopOf="parent"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toTopOf="parent" />

    <com.google.android.material.card.MaterialCardView
        android:id="@+id/cardProfileImage"
        android:layout_width="90dp"
        android:layout_height="90dp"
        android:layout_marginStart="24dp"
        android:layout_marginTop="50dp"
        app:cardCornerRadius="45dp"
        app:cardElevation="4dp"
        app:strokeColor="#FFFFFF"
        app:strokeWidth="3dp"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toTopOf="parent">

        <ImageView
            android:id="@+id/imgProfile"
            android:layout_width="match_parent"
            android:layout_height="match_parent"
            android:contentDescription="Foto Pengembang"
            android:scaleType="centerCrop"
            android:src="@drawable/developer" />
    </com.google.android.material.card.MaterialCardView>

    <!-- 3. NAMA UTAMA MAHASISWA (Dikunci Tepat di Sebelah Kanan Foto Profil) -->

    <!-- STATUS WORK / ROLE (Dikunci di Bawah Nama Utama) -->

    <!-- INSTITUSI KAMPUS (Dikunci di Bawah Status Role) -->

    <!-- 4. PANEL INFORMASI HORIZONTAL (NIM & PRODI Ringkas Bergaya Feed) -->

    <!-- 5. TABLAYOUT: Dikunci Kokoh Tepat di Bawah Panel Horizontal -->

    <!-- 6. WADAH HALAMAN GESER VIEWPAGER2: Area Sangat Luas Menghabiskan Sisa Layar -->

    <TextView
        android:id="@+id/tvName"
        android:layout_width="202dp"
        android:layout_height="0dp"
        android:layout_marginTop="24dp"
        android:text="Muhammad Farid"
        android:textColor="#222222"
        android:textSize="22sp"
        android:textStyle="bold"
        app2:layout_constraintEnd_toEndOf="parent"
        app2:layout_constraintHorizontal_bias="0.497"
        app2:layout_constraintStart_toStartOf="parent"
        app2:layout_constraintTop_toTopOf="@+id/headerBackground"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toEndOf="@id/cardProfileImage"
        app:layout_constraintTop_toBottomOf="@id/headerBackground" />

    <TextView
        android:id="@+id/tvRole"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_marginTop="60dp"
        android:text="Android Developer"
        android:textColor="#A15BE7"
        android:textSize="14sp"
        android:textStyle="bold"
        app2:layout_constraintEnd_toEndOf="parent"
        app2:layout_constraintHorizontal_bias="0.498"
        app2:layout_constraintStart_toStartOf="parent"
        app2:layout_constraintTop_toBottomOf="@+id/tvName"
        app:layout_constraintStart_toStartOf="@id/tvName"
        app:layout_constraintTop_toBottomOf="@id/tvName" />

    <LinearLayout
        android:id="@+id/layoutInfoHorizontal"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginHorizontal="24dp"
        android:layout_marginTop="24dp"
        android:background="#F8F9FA"
        android:orientation="horizontal"
        android:paddingVertical="12dp"
        android:weightSum="2"
        app2:layout_constraintEnd_toEndOf="parent"
        app2:layout_constraintHorizontal_bias="0.333"
        app2:layout_constraintStart_toStartOf="parent"
        app2:layout_constraintTop_toBottomOf="@+id/headerBackground"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toBottomOf="@id/cardProfileImage">

        <!-- BLOK PENAMPIL NIM -->
        <LinearLayout
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:gravity="center"
            android:orientation="vertical">

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="2457301079"
                android:textColor="#222222"
                android:textSize="16sp"
                android:textStyle="bold" />

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="NIM"
                android:textColor="#888888"
                android:textSize="12sp" />
        </LinearLayout>

        <!-- SEPARATOR / GARIS VERTIKAL TENGAH -->
        <View
            android:layout_width="1dp"
            android:layout_height="match_parent"
            android:background="#E0E0E0" />

        <!-- BLOK PENAMPIL PROGRAM STUDI -->
        <LinearLayout
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:gravity="center"
            android:orientation="vertical">

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Sistem Informasi"
                android:textColor="#222222"
                android:textSize="16sp"
                android:textStyle="bold" />

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Program Studi"
                android:textColor="#888888"
                android:textSize="12sp" />
        </LinearLayout>
    </LinearLayout>

    <com.google.android.material.tabs.TabLayout
        android:id="@+id/tabLayoutProfile"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginTop="16dp"
        android:background="#FFFFFF"
        app2:layout_constraintEnd_toEndOf="parent"
        app2:layout_constraintHorizontal_bias="1.0"
        app2:layout_constraintStart_toStartOf="parent"
        app2:layout_constraintTop_toBottomOf="@+id/layoutInfoHorizontal"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toBottomOf="@id/layoutInfoHorizontal"
        app:tabIndicatorColor="#A15BE7"
        app:tabSelectedTextColor="#A15BE7"
        app:tabTextColor="#757575" />

    <androidx.viewpager2.widget.ViewPager2
        android:id="@+id/viewPagerProfile"
        android:layout_width="match_parent"
        android:layout_height="0dp"
        app2:layout_constraintEnd_toEndOf="parent"
        app2:layout_constraintHorizontal_bias="0.0"
        app2:layout_constraintStart_toStartOf="parent"
        app2:layout_constraintTop_toBottomOf="@+id/tabLayoutProfile"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toBottomOf="@id/tabLayoutProfile" />

</androidx.constraintlayout.widget.ConstraintLayout>

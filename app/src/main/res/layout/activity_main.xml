<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:id="@+id/main"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="#FFFFFF"
    android:padding="24dp"
    tools:context=".MainActivity">

    <!-- Header Dashboard -->
    <TextView
        android:id="@+id/tvJudul"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_marginTop="16dp"
        android:text="Dashboard 👋"
        android:textSize="28sp"
        android:textStyle="bold"
        android:textColor="#000000"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toTopOf="parent"/>

    <TextView
        android:id="@+id/tvDeskripsi"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_marginTop="4dp"
        android:text="Pilih menu navigasi di bawah ini"
        android:textSize="14sp"
        android:textColor="#757575"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toBottomOf="@+id/tvJudul"/>

    <!-- Bagian Isi Menu Utama (Scrollable agar aman di layar HP kecil) -->
    <androidx.core.widget.NestedScrollView
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_marginTop="24dp"
        android:layout_marginBottom="16dp"
        android:fillViewport="true"
        app:layout_constraintBottom_toTopOf="@+id/btnLogout"
        app:layout_constraintTop_toBottomOf="@+id/tvDeskripsi">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical">

            <!-- BANNER UTAMA: Halaman Utama (Dibuat paling besar & mencolok) -->
            <Button
                android:id="@+id/btnUtama"
                android:layout_width="match_parent"
                android:layout_height="120dp"
                android:backgroundTint="#4B0082"
                android:text="Masuk ke Halaman Utama"
                android:textAllCaps="false"
                android:textSize="18sp"
                android:textStyle="bold"
                app:cornerRadius="16dp" />

            <!-- Sub Judul untuk Menu Tambahan -->
            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginTop="24dp"
                android:layout_marginBottom="12dp"
                android:text="Menu Aplikasi"
                android:textSize="16sp"
                android:textStyle="bold"
                android:textColor="#000000" />

            <!-- GRID BARIS 1: Rumus & About Us (Bersebelahan) -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal">

                <Button
                    android:id="@+id/btnRumus"
                    android:layout_width="0dp"
                    android:layout_height="110dp"
                    android:layout_weight="1"
                    android:layout_marginEnd="8dp"
                    android:backgroundTint="#4B0082"
                    android:text="Rumus Bangun\nDatar &amp; Ruang"
                    android:textAllCaps="false"
                    android:textSize="14sp"
                    app:cornerRadius="16dp" />

                <Button
                    android:id="@+id/btnCustom1"
                    style="@style/Widget.MaterialComponents.Button.OutlinedButton"
                    android:layout_width="0dp"
                    android:layout_height="110dp"
                    android:layout_weight="1"
                    android:layout_marginStart="8dp"
                    android:text="About Us"
                    android:textAllCaps="false"
                    android:textColor="#4B0082"
                    app:cornerRadius="16dp"
                    app:strokeColor="#4B0082" />
            </LinearLayout>

            <!-- GRID BARIS 2: Information (Berukuran Penuh di Bawahnya) -->
            <Button
                android:id="@+id/btnCustom2"
                style="@style/Widget.MaterialComponents.Button.OutlinedButton"
                android:layout_width="match_parent"
                android:layout_height="60dp"
                android:layout_marginTop="16dp"
                android:text="Information Center"
                android:textAllCaps="false"
                android:textColor="#4B0082"
                app:cornerRadius="16dp"
                app:strokeColor="#4B0082" />

        </LinearLayout>
    </androidx.core.widget.NestedScrollView>

    <!-- Logout Button: Tetap kokoh di bagian paling bawah -->
    <Button
        android:id="@+id/btnLogout"
        android:layout_width="match_parent"
        android:layout_height="55dp"
        android:backgroundTint="#F44336"
        android:text="Logout dari Akun"
        android:textAllCaps="false"
        android:textSize="15sp"
        android:textStyle="bold"
        app:cornerRadius="14dp"
        app:layout_constraintBottom_toBottomOf="parent" />

</androidx.constraintlayout.widget.ConstraintLayout>
